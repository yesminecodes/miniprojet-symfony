{% extends 'base.html.twig' %}

{% block title %}Your Shopping Cart{% endblock %}

{% block body %}

<div class="container categories-page mt-5">
    <h1>Your Cart</h1>

    <table class="table mt-4">
        <thead>
            <tr>
                <th>Product</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Subtotal</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for item in items %}
                <tr>
                    <td>{{ item.product.name }}</td>
                    <td>{{ item.product.price }} €</td>
                    <td>{{ item.quantity }}</td>
                    <td class="fw-bold">{{ item.product.price * item.quantity }} €</td>
                    <td class="text-end">
                        <a href="{{ path('app_cart_remove_product', {id: item.product.id}) }}" class="btn btn-danger btn-sm rounded-3">
                            Delete
                        </a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="text-center py-4">Your basket is empty.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    {% if items|length > 0 %}
        <div class="d-flex justify-content-between align-items-center mt-4">
            <h3>Total: <span class="text-primary">{{ total }} €</span></h3>
            <div>
                <a href="{{ path('app_cart_clear') }}" class="btn btn-outline-danger rounded-pill me-2">Clear Cart</a>
                <a href="{{ path('app_order') }}" class="btn btn-primary rounded-pill">Checkout</a>
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}