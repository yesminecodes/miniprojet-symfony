{% extends 'base.html.twig' %}

{% block title %}Product{% endblock %}

{% block body %}
<div class="categories-page">

    <h1>
        Product Details
        <a href="{{ path('app_product_index') }}" class="btn btn-primary">← Back</a>
    </h1>

    <table>
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ product.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td><strong>{{ product.name }}</strong></td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ product.description }}</td>
            </tr>
            <tr>
                <th>Price</th>
                <td>{{ product.price }} €</td>
            </tr>
        </tbody>
    </table>

    <div style="margin-top: 20px; display:flex; gap:10px;">

        <a href="{{ path('app_product_edit', {'id': product.id}) }}" class="btn btn-primary">
            Edit
        </a>
        <a href="{{ path('app_product_add_stock_history', {'id': product.id}) }}" class="btn btn-info" style="color: white;">
            Stock History
        </a>
        {{ include('product/_delete_form.html.twig') }}

    </div>

</div>
{% endblock %}