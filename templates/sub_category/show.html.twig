{% extends 'base.html.twig' %}

{% block title %}SubCategory{% endblock %}

{% block body %}
<div class="categories-page">
    <h1>
        Sub Category
        <div>
            <a href="{{ path('app_sub_category_index') }}" class="btn btn-primary">Back to list</a>
            <a href="{{ path('app_sub_category_edit', {'id': sub_category.id}) }}" class="btn btn-primary">Edit</a>
        </div>
    </h1>

    <table>
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ sub_category.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ sub_category.name }}</td>
            </tr>
        </tbody>
    </table>

    {{ include('sub_category/_delete_form.html.twig') }}
</div>
{% endblock %}