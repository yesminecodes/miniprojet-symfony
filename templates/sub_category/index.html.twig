{% extends 'base.html.twig' %}

{% block title %}SubCategory index{% endblock %}

{% block body %}
<div class="categories-page">
    <h1>
        Sub Categories
        <a href="{{ path('app_sub_category_new') }}" class="btn btn-success">+ New</a>
    </h1>

    <table>
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Category</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for sub_category in sub_categories %}
            <tr>
                <td>{{ sub_category.id }}</td>
                <td>{{ sub_category.name }}</td>
                <td>{{ sub_category.category.name }}</td>
                <td>
                    <a href="{{ path('app_sub_category_edit', {'id': sub_category.id}) }}" class="btn btn-primary">Edit</a>
                    <a href="{{ path('app_sub_category_show', {'id': sub_category.id}) }}" class="btn btn-primary">Show</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3" style="text-align:center; color: var(--text-muted); padding: 2rem;">
                    No records found.
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}