<nav class="navbar navbar-expand-lg bg-body-tertiary">
  <div class="container-fluid">
    <a class="navbar-brand fw-bold" href="{{ path('app_home') }}">My Shop</a>
    
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarScroll" aria-controls="navbarScroll" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarScroll">
      <ul class="navbar-nav me-auto my-2 my-lg-0 navbar-nav-scroll" style="--bs-scroll-height: 100px;">
        <li class="nav-item">
          <a class="nav-link active" aria-current="page" href="{{ path('app_home') }}">Home</a>
        </li>

        {% if categories is defined %}
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            Categories
          </a>
          <ul class="dropdown-menu">
            {% for category in categories %}
              <li><span class="dropdown-item-text fw-bold text-primary">{{ category.name }}</span></li>
              {% for sub in category.subCategories %}
                <li>
                  <a class="dropdown-item ps-4" href="{{ path('app_product_filtrer', {'id': sub.id}) }}">
                  {{ sub.name }}
                  </a>
                </li>
              {% endfor %}
              {% if not loop.last %}<li><hr class="dropdown-divider"></li>{% endif %}
            {% endfor %}
          </ul>
        </li>
        {% endif %}

        {% if is_granted('ROLE_EDITOR') or is_granted('ROLE_ADMIN') %}
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle text-success" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            Orders Management
          </a>
          <ul class="dropdown-menu">
            <li>
                <a class="dropdown-item" href="{{ path('app_order_show', {'type': 'all'}) }}">All Orders</a>
            </li>
            <li><hr class="dropdown-divider"></li>
            <li>
                <a class="dropdown-item" href="{{ path('app_order_show', {'type': 'is-completed'}) }}">Delivered Orders</a>
            </li>
            <li>
                <a class="dropdown-item" href="{{ path('app_order_show', {'type': 'pay-online-not-delivered'}) }}">Paid Online (Not Delivered)</a>
            </li>
            <li>
                <a class="dropdown-item" href="{{ path('app_order_show', {'type': 'pay-online-completed'}) }}">Paid Online (Delivered)</a>
            </li>
          </ul>
        </li>
        {% endif %}

        {% if is_granted('ROLE_ADMIN') %}
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            Admin Panel
          </a>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="{{ path('app_product_index') }}">Manage Products</a></li>
            <li><a class="dropdown-item" href="{{ path('app_category') }}">Manage Categories</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" href="{{ path('app_user') }}">Users</a></li>
          </ul>
        </li>
        {% endif %}
      </ul>

      <div class="d-flex align-items-center">
          <ul class="navbar-nav mb-2 mb-lg-0 me-3">
            <li class="nav-item me-2">
                <a class="nav-link position-relative" href="{{ path('app_cart') }}">
                    Cart
                </a>
            </li>

            {% if app.user %}
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle fw-bold text-dark" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                  {{ app.user.userIdentifier }}
                </a>
                <ul class="dropdown-menu dropdown-menu-end">
                  <li><a class="dropdown-item" href="#">My Profile</a></li>
                  <li><hr class="dropdown-divider"></li>
                  <li><a class="dropdown-item text-danger" href="{{ path('app_logout') }}">Logout</a></li>
                </ul>
              </li>
            {% else %}
              <li class="nav-item"><a class="nav-link" href="{{ path('app_login') }}">Login</a></li>
              <li class="nav-item"><a class="nav-link btn btn-primary btn-sm text-white ms-2" href="{{ path('app_register') }}">Register</a></li>
            {% endif %}
          </ul>

          <form class="d-flex" role="search" action="{{ path('app_home') }}" method="GET">
            <input 
                class="form-control me-2" 
                type="search" 
                name="q" 
                placeholder="Search product..." 
                aria-label="Search"
                value="{{ searchQuery|default('') }}"
            >
            <button class="btn btn-outline-success" type="submit">Search</button>
          </form>
      </div>

    </div>
  </div>
</nav>