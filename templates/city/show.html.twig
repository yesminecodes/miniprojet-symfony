{% extends 'base.html.twig' %}

{% block title %}City{% endblock %}

{% block body %}
<div class="categories-page">
    <h1>
        City
        <div>
            <a href="{{ path('app_city_index') }}" class="btn btn-primary">Back to list</a>
            <a href="{{ path('app_city_edit', {'id': city.id}) }}" class="btn btn-primary">Edit</a>
        </div>
    </h1>

    <table>
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ city.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ city.name }}</td>
            </tr>
            <tr>
                <th>Shipping Cost</th>
                <td>{{ city.shippingCost }}</td>
            </tr>
        </tbody>
    </table>

    {{ include('city/_delete_form.html.twig') }}
</div>
{% endblock %}