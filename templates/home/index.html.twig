{% extends 'base.html.twig' %}

{% block body %}
<div class="container mt-5">
    <h1 class="mb-4">Our Products</h1>
    
    <div class="row">
        {% for product in products %}
            <div class="col-md-3 mb-4">
                <div class="card h-100 shadow-sm">
                    <img src="{{ asset('uploads/images/' ~ product.image) }}" class="card-img-top" alt="{{ product.name }}" style="height: 200px; object-fit: cover;">
                    
                    <div class="card-body">
                        <h5 class="card-title">
                            <a href="{{ path('app_product_show_public', {'id': product.id}) }}" class="text-decoration-none text-dark">
                                {{ product.name }}
                            </a>
                        </h5>
                        <p class="card-text text-muted">
                            {{ product.description|slice(0, 50) }}...
                        </p>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="h5 mb-0 text-primary">{{ product.price }} €</span>
                            <a href="{{ path('app_cart_add', {'id': product.id}) }}" class="btn btn-outline-primary">Add to Cart</a>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12">
                <p class="alert alert-info">No products found.</p>
            </div>
        {% endfor %}
    </div>

    <div class="d-flex justify-content-center mt-4">
        {{ knp_pagination_render(products, 'layouts/pagination_template.html.twig') }}
    </div>
</div>
{% endblock %}