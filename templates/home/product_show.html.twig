{% extends 'base.html.twig' %}

{% block body %}
<div class="container mt-5">
    <div class="row">
        <div class="col-md-6">
            <img src="{{ asset('uploads/images/' ~ product.image) }}" class="img-fluid rounded shadow" alt="{{ product.name }}">
        </div>

        <div class="col-md-6">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Home</a></li>
                    <li class="breadcrumb-item active">{{ product.name }}</li>
                </ol>
            </nav>
            
            <h1 class="display-5 fw-bold">{{ product.name }}</h1>
            <h2 class="text-primary my-3">{{ product.price }} €</h2>
            <hr>
            <p class="lead">{{ product.description }}</p>
            
            <div class="mt-4">
                <p><strong>Stock available:</strong> {{ product.stock }} units</p>
                <button class="btn btn-primary btn-lg px-5">Add to Cart</button>
            </div>
        </div>
    </div>

    <div class="mt-5 pt-5 border-top">
    <h3>You might also like</h3>
    <div class="row mt-4">
        {% for p in latestProducts %} 
        <div class="col-md-3 mb-4">
            <div class="card h-100 shadow-sm">
                <img src="{{ asset('uploads/images/' ~ p.image) }}" class="card-img-top" alt="{{ p.name }}" style="height: 200px; object-fit: cover;">
                
                <div class="card-body">
                    <h5 class="card-title">
                        <a href="{{ path('app_product_show_public', {'id': p.id}) }}" class="text-decoration-none text-dark">
                            {{ p.name }}
                        </a>
                    </h5>
                    <p class="card-text text-muted">
                        {{ p.description|slice(0, 50) }}...
                    </p>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="h5 mb-0 text-primary">{{ p.price }} €</span>
                        <a href="#" class="btn btn-outline-primary btn-sm">Add to Cart</a>
                    </div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
</div>
{% endblock %}